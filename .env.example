# CORS: не задано или * = любой origin (удобно для dev). Иначе список через запятую:
# CORS_ORIGIN=http://localhost:3000,https://app.example.com
CORS_ORIGIN=*

# Порт HTTP (локально / PM2). Для PM2 см. ecosystem.config.cjs — по умолчанию 3013.
# PORT=3013

# JWT (обязательно JWT_ACCESS_SECRET)
JWT_ACCESS_SECRET=замените_на_длинную_случайную_строку_минимум_32_символа
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_DAYS=14

# Database — либо одна строка (Vercel / Neon / Supabase и т.д.):
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
# (допустимо имя DB_URL)
# Если SSL нужен отдельно от строки: DB_SSL=true
#
# Либо отдельные поля (локально / docker-compose):
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=robomind
DB_PASSWORD=robomind
DB_NAME=robomind

# TypeORM: false = только миграции (рекомендуется)
DB_SYNC=false

# OpenAI (ИИ-модули)
OPENAI_API_KEY=
OPENAI_MODEL_CHAT=gpt-4o-mini
OPENAI_MODEL_REASONING=gpt-4o-mini
OPENAI_WHISPER_MODEL=whisper-1
AI_CHAT_DAILY_LIMIT=30
AI_RECOMMENDATIONS_DAILY_LIMIT=10
AI_TEXT_GRADE_DAILY_LIMIT=200
# Язык ответов ИИ для учеников, если в запросе не передан language: kk (қазақша) | ru
AI_STUDENT_REPLY_LANGUAGE=kk

# Загрузки для блоков курса (фото/видео/файлы) → URL в fileUrl блока
UPLOAD_DIR=uploads
UPLOAD_MAX_IMAGE_MB=25
UPLOAD_MAX_VIDEO_MB=512
UPLOAD_MAX_FILE_MB=100

# Лимит устройств на ученика (вход блокируется, админы получают уведомление)
MAX_STUDENT_DEVICES=2
# Только для разработки: вход без проверки пароля
# AUTH_SKIP_PASSWORD=true

# Первый супер-админ (npm run seed:super-admin) — не коммитить реальные значения
# SUPER_ADMIN_EMAIL=admin@example.com
# SUPER_ADMIN_PASSWORD=минимум_8_символов
